<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- MDC：issue_id、issue_identifier、session_id（未设置时输出空段） -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5p [%t] %logger{36} [issue_id=%X{issue_id:-}] [issue_identifier=%X{issue_identifier:-}] [session_id=%X{session_id:-}] - %msg%n%ex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
