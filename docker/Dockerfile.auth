# syntax=docker/dockerfile:1.7

FROM maven:3.9.11-eclipse-temurin-21 AS build
WORKDIR /workspace

COPY . .

RUN mvn -B -pl artemis-auth -am package -DskipTests

FROM eclipse-temurin:21-jre
WORKDIR /app

COPY --from=build /workspace/artemis-auth/target/artemis-auth-*.jar /app/app.jar

EXPOSE 9200

ENTRYPOINT ["java", "-jar", "/app/app.jar"]
